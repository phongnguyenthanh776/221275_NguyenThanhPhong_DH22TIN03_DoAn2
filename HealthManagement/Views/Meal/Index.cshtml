@model List<ThucDon>

@{
    ViewData["Title"] = "Thực đơn";
    var loaiMonAn = ViewBag.LoaiMonAn as string;
}

<div class="row mb-4">
    <div class="col-12">
        <h2><i class="bi bi-egg-fried"></i> Thực đơn lành mạnh</h2>
        <p class="text-muted">Gợi ý món ăn dinh dưỡng cho sức khỏe</p>
    </div>
</div>

<!-- Filter -->
<div class="row mb-4">
    <div class="col-12">
        <div class="btn-group" role="group">
            <a asp-action="Index" class="btn @(string.IsNullOrEmpty(loaiMonAn) ? "btn-primary" : "btn-outline-primary")">
                <i class="bi bi-grid"></i> Tất cả
            </a>
            <a asp-action="Index" asp-route-loaiMonAn="Sáng" class="btn @(loaiMonAn == "Sáng" ? "btn-primary" : "btn-outline-primary")">
                <i class="bi bi-sunrise"></i> Sáng
            </a>
            <a asp-action="Index" asp-route-loaiMonAn="Trưa" class="btn @(loaiMonAn == "Trưa" ? "btn-primary" : "btn-outline-primary")">
                <i class="bi bi-sun"></i> Trưa
            </a>
            <a asp-action="Index" asp-route-loaiMonAn="Tối" class="btn @(loaiMonAn == "Tối" ? "btn-primary" : "btn-outline-primary")">
                <i class="bi bi-moon"></i> Tối
            </a>
            <a asp-action="Index" asp-route-loaiMonAn="Phụ" class="btn @(loaiMonAn == "Phụ" ? "btn-primary" : "btn-outline-primary")">
                <i class="bi bi-cup-straw"></i> Phụ
            </a>
        </div>
    </div>
</div>

<!-- Meals Grid -->
<div class="row">
    @if (Model != null && Model.Any())
    {
        @foreach (var meal in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100">
                    <div class="card-body">
                        <span class="badge bg-primary mb-2">@meal.LoaiMonAn</span>
                        <h5 class="card-title">@meal.TenMonAn</h5>
                        <p class="card-text text-muted small">@meal.MoTa</p>
                        
                        <div class="row text-center my-3">
                            <div class="col-6 border-end">
                                <small class="text-muted d-block">Calo</small>
                                <strong class="text-danger">@meal.Calo kcal</strong>
                            </div>
                            <div class="col-6">
                                <small class="text-muted d-block">Protein</small>
                                <strong class="text-success">@meal.Protein g</strong>
                            </div>
                        </div>

                        <div class="row text-center">
                            <div class="col-6 border-end">
                                <small class="text-muted d-block">Carbs</small>
                                <strong class="text-warning">@meal.Carbs g</strong>
                            </div>
                            <div class="col-6">
                                <small class="text-muted d-block">Fat</small>
                                <strong class="text-info">@meal.Fat g</strong>
                            </div>
                        </div>
                    </div>
                    <div class="card-footer">
                        <a asp-action="Details" asp-route-id="@meal.MaMonAn" class="btn btn-sm btn-outline-primary w-100">
                            <i class="bi bi-info-circle"></i> Chi tiết
                        </a>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12">
            <div class="alert alert-info">
                <i class="bi bi-info-circle"></i> Chưa có món ăn nào.
            </div>
        </div>
    }
</div>
