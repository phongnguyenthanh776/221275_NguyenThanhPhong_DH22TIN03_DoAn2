@model HoSoSucKhoe

@{
    ViewData["Title"] = "Hồ sơ sức khỏe";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <h4><i class="bi bi-person-lines-fill"></i> Hồ sơ sức khỏe của bạn</h4>
            </div>
            <div class="card-body">
                <form asp-action="Profile" method="post">
                    <input type="hidden" asp-for="MaHoSo" />
                    <input type="hidden" asp-for="MaNguoiDung" />

                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <h5 class="mb-3"><i class="bi bi-rulers"></i> Thông tin cơ bản</h5>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="ChieuCao" class="form-label"></label>
                            <div class="input-group">
                                <input asp-for="ChieuCao" class="form-control" placeholder="Ví dụ: 170" />
                                <span class="input-group-text">cm</span>
                            </div>
                            <span asp-validation-for="ChieuCao" class="text-danger"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="CanNang" class="form-label"></label>
                            <div class="input-group">
                                <input asp-for="CanNang" class="form-control" placeholder="Ví dụ: 65" />
                                <span class="input-group-text">kg</span>
                            </div>
                            <span asp-validation-for="CanNang" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="NhomMau" class="form-label"></label>
                        <select asp-for="NhomMau" class="form-select">
                            <option value="">-- Chọn nhóm máu --</option>
                            <option value="A">A</option>
                            <option value="B">B</option>
                            <option value="AB">AB</option>
                            <option value="O">O</option>
                        </select>
                    </div>

                    <hr />
                    <h5 class="mb-3"><i class="bi bi-clipboard-pulse"></i> Thông tin y tế</h5>

                    <div class="mb-3">
                        <label asp-for="TienSuBenhLy" class="form-label"></label>
                        <textarea asp-for="TienSuBenhLy" class="form-control" rows="3" 
                                  placeholder="Ví dụ: Tiền sử bệnh tim, cao huyết áp..."></textarea>
                    </div>

                    <div class="mb-3">
                        <label asp-for="DiUng" class="form-label"></label>
                        <textarea asp-for="DiUng" class="form-control" rows="2" 
                                  placeholder="Ví dụ: Dị ứng hải sản, phấn hoa..."></textarea>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ThuocDangDung" class="form-label"></label>
                        <textarea asp-for="ThuocDangDung" class="form-control" rows="2" 
                                  placeholder="Ví dụ: Aspirin, Vitamine C..."></textarea>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary btn-lg">
                            <i class="bi bi-check-circle"></i> Lưu hồ sơ
                        </button>
                        <a asp-controller="Home" asp-action="Dashboard" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left"></i> Quay lại Dashboard
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
