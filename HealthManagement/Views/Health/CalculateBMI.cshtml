@model BMIViewModel

@{
    ViewData["Title"] = "Tính BMI";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h4><i class="bi bi-calculator"></i> Tính chỉ số BMI</h4>
            </div>
            <div class="card-body">
                <div class="alert alert-info">
                    <strong>BMI (Body Mass Index)</strong> là chỉ số đánh giá cân nặng dựa trên chiều cao và cân nặng.
                </div>

                <form asp-action="CalculateBMI" method="post">
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <div class="mb-4">
                        <label asp-for="ChieuCao" class="form-label"></label>
                        <div class="input-group">
                            <input asp-for="ChieuCao" class="form-control form-control-lg" placeholder="Ví dụ: 170" />
                            <span class="input-group-text">cm</span>
                        </div>
                        <span asp-validation-for="ChieuCao" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="CanNang" class="form-label"></label>
                        <div class="input-group">
                            <input asp-for="CanNang" class="form-control form-control-lg" placeholder="Ví dụ: 65" />
                            <span class="input-group-text">kg</span>
                        </div>
                        <span asp-validation-for="CanNang" class="text-danger"></span>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary btn-lg">
                            <i class="bi bi-calculator"></i> Tính BMI
                        </button>
                        <a asp-action="BMIHistory" class="btn btn-outline-secondary">
                            <i class="bi bi-clock-history"></i> Xem lịch sử
                        </a>
                    </div>
                </form>

                <hr class="my-4" />

                <h6 class="mb-3">Bảng phân loại BMI (WHO):</h6>
                <table class="table table-sm table-bordered">
                    <thead>
                        <tr>
                            <th>BMI</th>
                            <th>Phân loại</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>&lt; 18.5</td>
                            <td><span class="badge bg-info">Thiếu cân</span></td>
                        </tr>
                        <tr>
                            <td>18.5 - 24.9</td>
                            <td><span class="badge bg-success">Bình thường</span></td>
                        </tr>
                        <tr>
                            <td>25.0 - 29.9</td>
                            <td><span class="badge bg-warning">Thừa cân</span></td>
                        </tr>
                        <tr>
                            <td>≥ 30.0</td>
                            <td><span class="badge bg-danger">Béo phì</span></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
