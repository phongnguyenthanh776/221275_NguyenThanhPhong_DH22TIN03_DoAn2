@{
    ViewData["Title"] = "Chọn loại bệnh dự đoán";
}

<nav aria-label="breadcrumb mb-4">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/Home/Dashboard">Dashboard</a></li>
        <li class="breadcrumb-item active" aria-current="page">Dự Đoán AI</li>
    </ol>
</nav>

<div class="row mb-4">
    <div class="col-12">
        <h2><i class="bi bi-robot"></i> Chọn loại bệnh cần dự đoán</h2>
        <p class="text-muted">Hệ thống hỗ trợ cả dự đoán từ chỉ số sức khỏe và dự đoán từ ảnh y tế.</p>
    </div>
</div>

<div class="alert alert-info alert-dismissible fade show" role="alert">
    <strong>Lưu ý:</strong> Kết quả chỉ có tính chất hỗ trợ, không thay thế chẩn đoán của bác sĩ.
    <a href="/Health/AddMetric" class="alert-link">Cập nhật chỉ số sức khỏe</a>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
</div>

<div class="row">
    <div class="col-lg-4 col-md-6 mb-4">
        <div class="card h-100 shadow-sm disease-card" style="border-left: 5px solid #dc3545;">
            <div class="card-body">
                <div class="text-danger fs-1 mb-2"><i class="bi bi-heart-fill"></i></div>
                <h5 class="card-title fw-bold">Bệnh Tim</h5>
                <p class="card-text text-muted">Heart Disease</p>
                <a href="/Prediction/PredictHeartDisease" class="btn btn-danger w-100">Dự đoán ngay</a>
            </div>
        </div>
    </div>

    <div class="col-lg-4 col-md-6 mb-4">
        <div class="card h-100 shadow-sm disease-card" style="border-left: 5px solid #fd7e14;">
            <div class="card-body">
                <div class="text-warning fs-1 mb-2"><i class="bi bi-droplet-fill"></i></div>
                <h5 class="card-title fw-bold">Bệnh Tiểu Đường</h5>
                <p class="card-text text-muted">Diabetes</p>
                <a href="/Prediction/PredictDiabetes" class="btn btn-warning w-100">Dự đoán ngay</a>
            </div>
        </div>
    </div>

    <div class="col-lg-4 col-md-6 mb-4">
        <div class="card h-100 shadow-sm disease-card" style="border-left: 5px solid #d63384;">
            <div class="card-body">
                <div style="color: #d63384; font-size: 2.25rem;" class="mb-2"><i class="bi bi-activity"></i></div>
                <h5 class="card-title fw-bold">Đột Quỵ</h5>
                <p class="card-text text-muted">Stroke</p>
                <a href="/Prediction/PredictStroke" class="btn btn-primary w-100">Dự đoán ngay</a>
            </div>
        </div>
    </div>

    <div class="col-lg-4 col-md-6 mb-4">
        <div class="card h-100 shadow-sm disease-card" style="border-left: 5px solid #dc3545;">
            <div class="card-body">
                <div style="color: #dc3545; font-size: 2.25rem;" class="mb-2"><i class="bi bi-speedometer2"></i></div>
                <h5 class="card-title fw-bold">Huyết Áp Cao</h5>
                <p class="card-text text-muted">Hypertension</p>
                <a href="/Prediction/PredictHypertension" class="btn btn-danger w-100">Dự đoán ngay</a>
            </div>
        </div>
    </div>

    <div class="col-lg-4 col-md-6 mb-4">
        <div class="card h-100 shadow-sm disease-card" style="border-left: 5px solid #0d6efd;">
            <div class="kidney-icon ms-3 mt-3 mb-2" aria-hidden="true">
                <svg viewBox="0 0 64 64" role="img" focusable="false">
                    <defs>
                        <linearGradient id="kidneyGrad" x1="0" y1="0" x2="1" y2="1">
                            <stop offset="0%" stop-color="#60a5fa"></stop>
                            <stop offset="100%" stop-color="#2563eb"></stop>
                        </linearGradient>
                    </defs>
                    <ellipse cx="21" cy="28" rx="10" ry="15" transform="rotate(-16 21 28)" fill="url(#kidneyGrad)" stroke="#1d4ed8" stroke-width="2"></ellipse>
                    <ellipse cx="43" cy="28" rx="10" ry="15" transform="rotate(16 43 28)" fill="url(#kidneyGrad)" stroke="#1d4ed8" stroke-width="2"></ellipse>
                    <path d="M28 37 Q32 42 32 48" stroke="#93c5fd" stroke-width="3" fill="none" stroke-linecap="round"></path>
                    <path d="M36 37 Q32 42 32 48" stroke="#93c5fd" stroke-width="3" fill="none" stroke-linecap="round"></path>
                </svg>
            </div>
            <div class="card-body pt-0">
                <h5 class="card-title fw-bold">Sỏi Thận (Ảnh CT)</h5>
                <p class="card-text text-muted">Kidney Stone Image</p>
                <p class="small">Tải ảnh CT vùng thận để dự đoán nguy cơ sỏi.</p>
                <a href="/Prediction/PredictKidneyStoneImage" class="btn btn-primary w-100">Tải ảnh và dự đoán</a>
            </div>
        </div>
    </div>

    <div class="col-lg-4 col-md-6 mb-4">
        <div class="card h-100 shadow-sm disease-card" style="border-left: 5px solid #198754;">
            <div class="text-success fs-1 mb-2 ms-3 mt-3"><i class="bi bi-lungs"></i></div>
            <div class="card-body pt-0">
                <h5 class="card-title fw-bold">Viêm Phổi (Ảnh X-Quang)</h5>
                <p class="card-text text-muted">Pneumonia Image</p>
                <p class="small">Tải ảnh X-quang ngực để dự đoán nguy cơ viêm phổi.</p>
                <a href="/Prediction/PredictPneumoniaImage" class="btn btn-success w-100">Tải ảnh và dự đoán</a>
            </div>
        </div>
    </div>
</div>

<style>
    .disease-card {
        cursor: pointer;
        transition: all 0.25s ease;
    }

    .kidney-icon {
        width: 62px;
        height: 62px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .kidney-icon svg {
        width: 100%;
        height: 100%;
        filter: drop-shadow(0 4px 8px rgba(37, 99, 235, 0.25));
    }

    .disease-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.15) !important;
    }
</style>
