@{
    ViewData["Title"] = "Dự đoán Sỏi Thận từ Ảnh CT";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h4 class="d-flex align-items-center gap-2 mb-0">
                    <span class="kidney-icon-sm" aria-hidden="true">
                        <svg viewBox="0 0 64 64" role="img" focusable="false">
                            <ellipse cx="21" cy="28" rx="10" ry="15" transform="rotate(-16 21 28)" fill="#bfdbfe" stroke="#ffffff" stroke-width="2"></ellipse>
                            <ellipse cx="43" cy="28" rx="10" ry="15" transform="rotate(16 43 28)" fill="#bfdbfe" stroke="#ffffff" stroke-width="2"></ellipse>
                            <path d="M28 37 Q32 42 32 48" stroke="#ffffff" stroke-width="3" fill="none" stroke-linecap="round"></path>
                            <path d="M36 37 Q32 42 32 48" stroke="#ffffff" stroke-width="3" fill="none" stroke-linecap="round"></path>
                        </svg>
                    </span>
                    <span>Dự đoán Sỏi Thận từ Ảnh CT</span>
                </h4>
            </div>
            <div class="card-body">
                <div class="alert alert-warning">
                    <strong>Lưu ý:</strong> Ảnh nên là CT thận rõ nét, định dạng JPG/PNG.
                </div>

                @if (!ViewData.ModelState.IsValid)
                {
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>
                }

                <form asp-action="PredictKidneyStoneImage" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label fw-bold">Chọn ảnh CT thận *</label>
                        <input type="file" name="imageFile" class="form-control" accept=".jpg,.jpeg,.png,.bmp" required />
                        <small class="text-muted">Khuyến nghị ảnh rõ nét, không bị mờ hoặc thiếu vùng thận.</small>
                    </div>

                    <div class="d-grid gap-2 mt-4">
                        <button type="submit" class="btn btn-primary btn-lg">
                            <i class="bi bi-upload"></i> Tải ảnh và dự đoán
                        </button>
                        <a href="/Prediction/SelectDisease" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left"></i> Quay lại chọn bệnh
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    .kidney-icon-sm {
        width: 28px;
        height: 28px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .kidney-icon-sm svg {
        width: 100%;
        height: 100%;
    }
</style>
